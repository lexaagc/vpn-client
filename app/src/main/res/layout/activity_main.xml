<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D9D9D9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Заголовок -->
        <TextView
            android:text="Барсик_VPN"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FF9800"
            android:layout_marginBottom="20dp"/>

        <!-- Поле ключа -->
        <EditText
            android:id="@+id/keyInput"
            android:hint="Ключ еще не вставлен..."
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <!-- Кнопка вставить -->
        <Button
            android:id="@+id/pasteBtn"
            android:text="Вставить ключ из буфера"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Кнопка старт -->
        <Button
            android:id="@+id/startBtn"
            android:text="Старт"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- Кот (пока без картинки, потом добавим) -->
        <ImageView
            android:id="@+id/catImage"
            android:src="@android:drawable/ic_menu_gallery"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginBottom="12dp"/>

        <!-- Статус -->
        <TextView
            android:id="@+id/statusText"
            android:text="Система готова..."
            android:textColor="#00C853"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <!-- Версия -->
        <TextView
            android:text="Версия: v1.0"
            android:textSize="12sp"
            android:textColor="#666666"/>

    </LinearLayout>
</ScrollView>